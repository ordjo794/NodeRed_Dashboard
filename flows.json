    {
        "id": "40a40e35d20220cc",
        "type": "function",
        "z": "6bba2a6bf05fbba8",
        "name": "Format dashboard chat",
        "func": "const MAX_MESSAGES = 20;\n\nlet text = String(msg.payload || '').trim();\nlet media = [];\n\nconst mentions = msg.mentions || (msg.data && msg.data.mentions) || [];\nif (Array.isArray(mentions)) {\n    mentions.forEach(m => {\n        const regex = new RegExp(`<@!?${m.id}>`, 'g');\n        text = text.replace(regex, `@${m.username}`);\n    });\n}\n\nfunction addMedia(url, type) {\n    if (!url) return;\n    if (!media.some(m => m.url === url)) {\n        media.push({ type, url });\n    }\n}\n\nconst embeds = msg.embeds || (msg.data && msg.data.embeds) || [];\nif (Array.isArray(embeds)) {\n    embeds.forEach(embed => {\n        if (embed.video && embed.video.url) {\n            addMedia(embed.video.url, 'video');\n        } else if (embed.image && embed.image.url) {\n            addMedia(embed.image.url, 'image');\n        } else if (embed.thumbnail && embed.thumbnail.url) {\n            addMedia(embed.thumbnail.url, 'image');\n        }\n        if (embed.url && text.includes(embed.url)) {\n            text = text.replace(embed.url, '');\n        }\n    });\n}\n\nconst attachments = msg.attachments || (msg.data && msg.data.attachments);\nif (attachments) {\n    const attArray = Array.isArray(attachments) ? attachments : (typeof attachments.values === 'function' ? Array.from(attachments.values()) : Object.values(attachments));\n    attArray.forEach(att => {\n        if (att.url) {\n            const isVideo = att.contentType?.startsWith('video') || att.url.match(/\\.(mp4|webm|mov)($|\\?)/i);\n            const isImage = att.contentType?.startsWith('image') || att.url.match(/\\.(jpeg|jpg|gif|png|webp)($|\\?)/i);\n            if (isVideo) {\n                addMedia(att.url, 'video');\n            } else if (isImage) {\n                addMedia(att.url, 'image');\n            }\n            if (text.includes(att.url)) {\n                text = text.replace(att.url, '');\n            }\n        }\n    });\n}\n\nconst urlRegex = /(https?:\\/\\/[^\\s]+)/g;\nconst foundUrls = text.match(urlRegex) || [];\nfoundUrls.forEach(url => {\n    const isMediaFile = url.match(/\\.(gif|png|jpg|jpeg|webp|mp4|webm)($|\\?)/i);\n    const isGifPlatform = url.includes('tenor.com') || url.includes('giphy.com');\n    if (isMediaFile || isGifPlatform) {\n        if (isMediaFile) {\n            const type = url.match(/\\.(mp4|webm)($|\\?)/i) ? 'video' : 'image';\n            addMedia(url, type);\n        }\n        text = text.replace(url, '');\n    }\n});\n\ntext = text.replace(/\\s+/g, ' ').trim();\n\nif (!text && media.length === 0) {\n    return null;\n}\n\nconst author = msg.author?.globalName\n    || msg.author?.username\n    || msg.data?.author?.globalName\n    || msg.data?.author?.username\n    || 'Discord';\n\nlet avatar = \"https://cdn.discordapp.com/embed/avatars/0.png\";\nif (msg.author && typeof msg.author.displayAvatarURL === 'function') {\n    avatar = msg.author.displayAvatarURL();\n} else if (msg.data?.author && typeof msg.data.author.displayAvatarURL === 'function') {\n    avatar = msg.data.author.displayAvatarURL();\n} else if (msg.author?.avatarURL) {\n    avatar = msg.author.avatarURL;\n} else if (msg.data?.author?.avatarURL) {\n    avatar = msg.data.author.avatarURL;\n}\n\nconst now = new Date();\nconst time = now.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });\n\nlet messages = flow.get('discordGeneralChatLines') || [];\nmessages.push({ \n    id: msg.id,\n    time, \n    author, \n    text, \n    media, \n    avatar \n});\nmessages = messages.slice(-MAX_MESSAGES);\nflow.set('discordGeneralChatLines', messages);\n\nmsg.payload = messages;\nreturn msg;",
