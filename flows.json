        "type": "function",
        "z": "6bba2a6bf05fbba8",
        "name": "Format to /tellraw",
        "func": "// Block the bot from reading its own messages\nif (msg.author && msg.author.bot) return null;\n\nlet username = msg.author.username || \"Discord\";\nlet content = msg.payload;\n\n// Escape quotes safely\ncontent = content.replace(/\"/g, '\\\\\"');\n\n// Pass the exact raw string the rcon node expects with leading slash\nmsg.payload = `/tellraw @a {\"text\":\"[Discord] <${username}> ${content}\",\"color\":\"blue\"}`;\n\nreturn msg;",
