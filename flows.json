    {
        "id": "c583dbba76142659",
        "type": "ui-template",
        "z": "6bba2a6bf05fbba8",
        "group": "10ecf61e9acd3652",
        "page": "",
        "ui": "",
        "name": "Discord General Chat",
        "order": 4,
        "width": "7",
        "height": "7",
        "format": "<template>\n  <div class=\"discord-container\" ref=\"chatContainer\">\n    <div\n      v-for=\"(line, index) in ((msg && msg.payload) || [])\"\n      :key=\"index\"\n      class=\"discord-message\"\n    >\n      <div class=\"discord-avatar\">\n        <img :src=\"line.avatar || 'https://cdn.discordapp.com/embed/avatars/0.png'\" alt=\"Avatar\" />\n      </div>\n      <div class=\"discord-message-content\">\n        <div class=\"discord-message-header\">\n          <span class=\"discord-author\">{{ line.author }}</span>\n          <span class=\"discord-time\">Today at {{ line.time }}</span>\n        </div>\n        <div v-if=\"line.text\" class=\"discord-text\" v-html=\"line.text.replace(/(@\\w+)/g, '<span class=\\'mention\\'>$1</span>')\"></div>\n        <div v-if=\"line.media && line.media.length > 0\" class=\"discord-image-container\">\n          <template v-for=\"(item, i) in line.media\" :key=\"i\">\n            <video \n              v-if=\"item.type === 'video'\" \n              :src=\"item.url\" \n              class=\"discord-attachment\" \n              autoplay \n              loop \n              muted \n              playsinline \n              @loadeddata=\"scrollToBottom\"\n            ></video>\n            <img \n              v-else \n              :src=\"item.url\" \n              class=\"discord-attachment\" \n              loading=\"lazy\" \n              @load=\"scrollToBottom\" \n            />\n          </template>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  methods: {\n    scrollToBottom() {\n      const el = this.$refs.chatContainer;\n      if (el) {\n        el.scrollTop = el.scrollHeight;\n      }\n    }\n  },\n  mounted() {\n    this.$nextTick(() => {\n      this.scrollToBottom();\n\n      this.observer = new MutationObserver(() => {\n        this.scrollToBottom();\n      });\n\n      const el = this.$refs.chatContainer;\n      if (el) {\n        this.observer.observe(el, {\n          childList: true,\n          subtree: true\n        });\n      }\n    });\n  },\n  unmounted() {\n    if (this.observer) {\n      this.observer.disconnect();\n    }\n  }\n}\n</script>\n\n<style>\n.discord-container {\n  background-color: #313338;\n  color: #dbdee1;\n  font-family: \"gg sans\", \"Noto Sans\", \"Helvetica Neue\", Helvetica, Arial, sans-serif;\n  height: 100%;\n  min-height: 280px;\n  max-height: 350px;\n  overflow-y: auto;\n  padding: 8px 0;\n  border-radius: 6px;\n}\n.discord-container::-webkit-scrollbar {\n  width: 8px;\n}\n.discord-container::-webkit-scrollbar-track {\n  background: #2b2d31;\n  border-radius: 4px;\n}\n.discord-container::-webkit-scrollbar-thumb {\n  background: #1a1b1e;\n  border-radius: 4px;\n}\n.discord-message {\n  display: flex;\n  padding: 2px 16px 2px 16px;\n  margin-top: 17px;\n}\n.discord-message:hover {\n  background-color: #2e3035;\n}\n.discord-avatar {\n  margin-top: 2px;\n  margin-right: 16px;\n  width: 40px;\n  height: 40px;\n  border-radius: 50%;\n  overflow: hidden;\n  cursor: pointer;\n  flex-shrink: 0;\n}\n.discord-avatar img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n}\n.discord-message-content {\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n}\n.discord-message-header {\n  display: flex;\n  align-items: baseline;\n  margin-bottom: 2px;\n}\n.discord-author {\n  color: #f2f3f5;\n  font-weight: 500;\n  font-size: 16px;\n  margin-right: .25rem;\n  cursor: pointer;\n  overflow-wrap: anywhere;\n}\n.discord-author:hover {\n  text-decoration: underline;\n}\n.discord-time {\n  font-size: 0.75rem;\n  color: #949ba4;\n  margin-left: 4px;\n  white-space: nowrap;\n}\n.discord-text {\n  font-size: 1rem;\n  line-height: 1.375rem;\n  word-wrap: break-word;\n  user-select: text;\n  color: #dbdee1;\n  white-space: pre-wrap;\n}\n\n/* Mention Highlighting styling */\n.discord-text span.mention {\n  background-color: rgba(88, 101, 242, 0.3);\n  color: #dee0fc;\n  padding: 0 4px;\n  border-radius: 4px;\n  font-weight: 500;\n}\n\n.discord-image-container {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n  margin-top: 4px;\n}\n.discord-attachment {\n  max-width: 100%;\n  max-height: 250px;\n  border-radius: 8px;\n  object-fit: contain;\n  align-self: flex-start;\n}\n</style>",
