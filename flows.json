        "type": "function",
        "z": "6bba2a6bf05fbba8",
        "name": "Parse /list",
        "func": "const raw = msg.payload || '';\n\nif (raw.includes(\"Unknown command\") || raw.includes(\"error\") || raw === \"\") {\n    return null;\n}\n\nconst match = raw.match(/(\\d+).*?:(.*)?$/);\n\nif (match) {\n    const count = match[1];\n    const names = (match[2] || '').trim();\n\n    msg.payload = count === '0'\n        ? 'No players online'\n        : count + ' online: ' + names;\n} else {\n    return null;\n}\n\nreturn msg;",
